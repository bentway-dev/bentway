{
  "name": "@bentway/llama",
  "version": "0.3.0",
  "description": "llama.cpp / llama-server completion port for the bentway kernel",
  "keywords": [
    "bentway",
    "llm",
    "agent",
    "llama",
    "llama-cpp",
    "port"
  ],
  "homepage": "https://github.com/bentway-dev/bentway#readme",
  "bugs": {
    "url": "https://github.com/bentway-dev/bentway/issues"
  },
  "license": "Apache-2.0",
  "author": "Nathan Sentjens <nate@bentway.dev>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bentway-dev/bentway.git",
    "directory": "packages/llama"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./src/index.mjs"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "bash scripts/check-file-sizes.sh && bash scripts/check-api-report.sh"
  },
  "dependencies": {
    "@bentway/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
