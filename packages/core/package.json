{
  "name": "@bentway/core",
  "version": "0.1.0",
  "description": "Runtime-agnostic execution kernel for LLM agents: turn loop, neutral transcript, tool-call dispatch, and provider-agnostic stop/retry semantics",
  "keywords": [
    "bentway",
    "llm",
    "agent",
    "kernel",
    "turn-loop",
    "transcript"
  ],
  "homepage": "https://github.com/bentway-dev/bentway#readme",
  "bugs": {
    "url": "https://github.com/bentway-dev/bentway/issues"
  },
  "license": "Apache-2.0",
  "author": "Nathan Sentjens <nate@bentway.dev>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bentway-dev/bentway.git",
    "directory": "packages/core"
  },
  "type": "module",
  "exports": {
    "./turn-loop": {
      "types": "./dist/turn-loop.d.mts",
      "default": "./src/turn-loop.mjs"
    },
    "./transcript": {
      "types": "./dist/transcript.d.mts",
      "default": "./src/transcript.mjs"
    },
    "./tool-exec": {
      "types": "./dist/tool-exec.d.mts",
      "default": "./src/tool-exec.mjs"
    },
    "./normalize/stop-reason": {
      "types": "./dist/normalize/stop-reason.d.mts",
      "default": "./src/normalize/stop-reason.mjs"
    },
    "./normalize/retryable": {
      "types": "./dist/normalize/retryable.d.mts",
      "default": "./src/normalize/retryable.mjs"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "bash scripts/check-file-sizes.sh && bash scripts/check-api-report.sh"
  },
  "dependencies": {
    "@bentway/stream-json": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
